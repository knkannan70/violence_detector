<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Thumbnail Image -->
    <ImageView
        android:id="@+id/thumbnail_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="visible" />

    <!-- ExoPlayer View -->
    <com.google.android.exoplayer2.ui.StyledPlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="false"
        app:show_buffering="when_playing"
        android:visibility="gone" />

    <!-- Gradient scrim at bottom for readability -->
    <View
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_gravity="bottom"
        android:background="@drawable/gradient_scrim_bottom"
        android:importantForAccessibility="no" />

    <!-- Blocked Overlay -->
    <FrameLayout
        android:id="@+id/blocked_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#EE0A0A0A"
        android:visibility="gone">

        <!-- Blurred card behind text -->
        <LinearLayout
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:background="@drawable/blocked_card_bg">

            <!-- Block icon circle -->
            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/block_icon_circle_bg"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_block"
                    app:tint="#FF3B30" />

            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Content Blocked"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.02"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/blocked_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/violent_content_blocked"
                android:textColor="#99FFFFFF"
                android:textSize="13sp"
                android:gravity="center"
                android:lineSpacingExtra="3dp" />

        </LinearLayout>

    </FrameLayout>

    <!-- Loading Indicator -->
    <ProgressBar
        android:id="@+id/loading_indicator"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="center"
        android:indeterminateTint="#FFFFFF"
        android:visibility="gone" />

</FrameLayout>